    "    (\"Laryngeal prominence\", fmt_mean_minmax(*lm_all[\"larynx\"]), fmt_mean_minmax(*lm_L[\"larynx\"]), fmt_mean_minmax(*lm_R[\"larynx\"])),\n",
    "    (\"Superior border of clavicle\", fmt_mean_minmax(*lm_all[\"clavicle\"]), fmt_mean_minmax(*lm_L[\"clavicle\"]), fmt_mean_minmax(*lm_R[\"clavicle\"])),\n",
